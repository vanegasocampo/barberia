# Archivos de migración generados
*/migrations/*.py
*/migrations/*.pyc

# Archivos de configuración de VSCode
.vscode/

# Archivos estáticos y media
# /staticfiles/
# /media/

# Archivos de configuraciones locales
local_settings.py

# Archivos creados por collectstatic
#static/


