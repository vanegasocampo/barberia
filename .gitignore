# Entorno virtual
env/
venv/
ENV/
*.env

# Archivos de Python compilados
__pycache__/
*.py[cod]
*$py.class

# Archivos de log y temporales
*.log
*.pot
*.pyc
*.swp
*.swo
*.bak

# Archivos de base de datos (si usas sqlite)
